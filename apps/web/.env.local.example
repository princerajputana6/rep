# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# Database name (the connection string often omits it; without this it defaults to "test")
MONGODB_DB=rep

# Authentication (first-party email/username + password sessions)
# Generate a strong secret, e.g.  openssl rand -base64 48
AUTH_JWT_SECRET=change-me-to-a-long-random-secret

# Optional: override the seeded super admin (used by `npm run seed:superadmin`)
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=ChangeMe!2026
SUPERADMIN_EMAIL=superadmin@rep.local

# Email delivery (Resend) — onboarding + invite emails
RESEND_API_KEY=re_...
EMAIL_FROM=REP Platform <onboarding@yourdomain.com>

# Public base URL used in email links
NEXT_PUBLIC_APP_URL=http://localhost:3000
