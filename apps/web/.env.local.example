# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Admin auth (Super Admin + Company Admin password sessions — NOT Clerk)
# Generate a strong secret, e.g.  openssl rand -base64 48
ADMIN_JWT_SECRET=change-me-to-a-long-random-secret

# Optional: override the seeded super admin (used by `npm run seed:superadmin`)
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=ChangeMe!2026
SUPERADMIN_EMAIL=superadmin@rep.local

# Email delivery (Resend) — onboarding + invite emails
RESEND_API_KEY=re_...
EMAIL_FROM=REP Platform <onboarding@yourdomain.com>

# Public base URL used in email links
NEXT_PUBLIC_APP_URL=http://localhost:3000
