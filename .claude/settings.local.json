      "Bash(curl -s -i -X POST http://localhost:3000/api/v1/integrations/workfront/connectors -H 'Content-Type: application/json' -d '{\"name\":\"Workfront Sandbox\",\"baseUrl\":\"https://roar.sb02.workfront.com\",\"domain\":\"roar\",\"apiVersion\":\"v21.0\",\"authType\":\"API_KEY\",\"syncFrequencyMinutes\":15,\"apiKey\":\"x\"}')",
      "Bash(curl -s -o /dev/null -w \"HTTP %{http_code}\\\\n\" http://localhost:3001/api/v1/integrations/workfront/connectors)",
      "Bash(curl -s http://localhost:3001/api/v1/integrations/workfront/connectors)",
      "Bash(curl -s -X POST http://localhost:3001/api/v1/integrations/workfront/connectors -H 'Content-Type: application/json' -d '{\"name\":\"t\",\"baseUrl\":\"https://x.com\",\"domain\":\"x\",\"apiVersion\":\"v21.0\",\"authType\":\"API_KEY\",\"apiKey\":\"x\"}')",
      "Bash(curl -s -o /dev/null -w \"HTTP %{http_code}\\\\n\" http://localhost:3001/api/v1/integrations)",
