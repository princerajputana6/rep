      "Bash(kill 7432 7433)",
      "Bash(lsof -iTCP:3001 -sTCP:LISTEN -n -P)",
      "Bash(grep -qE \"Ready|started server|Local:\" /tmp/rep-dev.log)",
      "Read(//private/tmp/**)",
